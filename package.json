{
  "name": "sti-graph-validation",
  "version": "6.0.0",
  "description": "Pacote de auditoria e reanálise offline de agentes de autoria comportamental, transporte e GraphForge.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Joaoqueiroz-silva/sti-graph-validation.git"
  },
  "homepage": "https://github.com/Joaoqueiroz-silva/sti-graph-validation#readme",
  "bugs": {
    "url": "https://github.com/Joaoqueiroz-silva/sti-graph-validation/issues"
  },
  "scripts": {
    "test": "vitest run",
    "report:validate": "node analysis/validate-report.mjs",
    "report:validate:legacy": "node analysis/validate-report.mjs",
    "report:build": "node scripts/build-report-pdf.mjs --qa-dir tmp/report-pdf-qa",
    "article:validate": "node analysis/validate-article-v6.mjs",
    "links:check": "node scripts/check-local-links.mjs",
    "privacy:check": "node scripts/redact-public-artifacts.mjs --check && node scripts/check-public-artifacts.mjs",
    "manifest:v6:write": "node scripts/verify-manifest-v6.mjs --write",
    "manifest:v6:verify": "node scripts/verify-manifest-v6.mjs --verify",
    "validate": "npm run report:validate && npm run article:validate",
    "verify:offline": "npm test && npm run validate && npm run c3:freeze:check && npm run c4:groups:check && npm run c4:aggregate:check && npm run c4:sensitivity:check && npm run c4:judge:check && npm run c4:completion:check && npm run links:check && npm run privacy:check && npm run manifest:v6:verify",
    "c3:reanalyze": "node analysis/reanalyze-c3.mjs",
    "c3:freeze:write": "node analysis/build-c3-correction-manifest.mjs --write",
    "c3:freeze:check": "node analysis/build-c3-correction-manifest.mjs --check",
    "c4:aggregate": "node analysis/aggregate-campaign4.mjs --write",
    "c4:aggregate:check": "node analysis/aggregate-campaign4.mjs --check",
    "c4:groups:write": "node analysis/reanalyze-campaign4-public.mjs --write",
    "c4:groups:check": "node analysis/reanalyze-campaign4-public.mjs --check",
    "c4:sensitivity": "node analysis/campaign4-batch-cluster-sensitivity.mjs --write",
    "c4:sensitivity:check": "node analysis/campaign4-batch-cluster-sensitivity.mjs --check",
    "c4:judge:correct": "node analysis/correct-campaign4-judge-degeneracy.mjs --write",
    "c4:judge:check": "node analysis/correct-campaign4-judge-degeneracy.mjs --check",
    "c4:completion": "node analysis/build-campaign4-completion-manifest.mjs --write",
    "c4:completion:check": "node analysis/build-campaign4-completion-manifest.mjs --check",
    "materialize": "node materialize-dataset.mjs cases/ctat-6.17 --name frac-numberline-6.17",
    "eval": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17",
    "eval:one": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17 --limit 1",
    "eval:real": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17 --real",
    "eval:real:one": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17 --limit 1 --real",
    "judge": "node -r dotenv/config run-judge.mjs cases/ctat-6.17",
    "judge:one": "node -r dotenv/config run-judge.mjs cases/ctat-6.17 --limit 1",
    "judge:real": "node -r dotenv/config run-judge.mjs cases/ctat-6.17 --real",
    "judge:real:one": "node -r dotenv/config run-judge.mjs cases/ctat-6.17 --limit 1 --real",
    "aggregate": "node aggregate-campaign.mjs .",
    "models": "node -r dotenv/config models.mjs",
    "models:ping": "node -r dotenv/config models.mjs --ping",
    "fixtures:production": "node production-fidelity/build-ctat-fixtures.mjs",
    "preflight:production": "node production-fidelity/run-fixture-preflight.mjs"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "fast-check": "^4.8.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
