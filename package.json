{
  "name": "sti-graph-validation",
  "version": "1.0.0",
  "description": "Validação de grafos de comportamento de Sistemas Tutores Inteligentes (CTAT × agentes LLM) — pacote reprodutível e standalone.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "materialize": "node materialize-dataset.mjs cases/ctat-6.17 --name frac-numberline-6.17",
    "eval": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17",
    "eval:one": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17 --limit 1",
    "eval:real": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17 --real",
    "eval:real:one": "node -r dotenv/config run-ctat-eval.mjs cases/ctat-6.17 --limit 1 --real",
    "judge": "node -r dotenv/config run-judge.mjs cases/ctat-6.17",
    "judge:one": "node -r dotenv/config run-judge.mjs cases/ctat-6.17 --limit 1",
    "judge:real": "node -r dotenv/config run-judge.mjs cases/ctat-6.17 --real",
    "judge:real:one": "node -r dotenv/config run-judge.mjs cases/ctat-6.17 --limit 1 --real",
    "aggregate": "node aggregate-campaign.mjs ."
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "vitest": "^2.1.8",
    "fast-check": "^4.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
