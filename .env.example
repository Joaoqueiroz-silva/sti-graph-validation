# Copie este arquivo para `.env` e preencha. UMA chave basta (gerador + juiz via OpenRouter).
# Pegue sua chave em https://openrouter.ai/keys
OPENROUTER_API_KEY=

# (Opcional) trocar os modelos. Defaults = os usados no experimento original.
# GEN_MODEL=google/gemini-3.5-flash
# JUDGE_MODEL=z-ai/glm-4.5
# FALLBACK_MODEL=deepseek/deepseek-chat

# (Opcional) STI_LOG=debug  → mostra logs detalhados
