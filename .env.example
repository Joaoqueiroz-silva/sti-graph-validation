# ══════════════════════════════════════════════════════════════════════
#  CONFIGURAÇÃO DO EXPERIMENTO
#  1. Copie este arquivo:            cp .env.example .env
#  2. Cole a sua chave abaixo (crie grátis em https://openrouter.ai/keys)
#  3. Confira a configuração:        npm run models
# ══════════════════════════════════════════════════════════════════════

OPENROUTER_API_KEY=

# ──────────────────────────────────────────────────────────────────────
#  MODELOS (opcional; os padrões abaixo são os usados na campanha oficial)
#
#  Papel        Agente                        Modelo padrão              Temp.
#  gerador      3a, aluno avançado            google/gemini-3.5-flash    0.2
#  gerador      3b, aluno com dificuldades    google/gemini-3.5-flash    0.7
#  gerador      3c, aluno mediano             google/gemini-3.5-flash    0.4
#  juiz cego    validade + importância        z-ai/glm-4.5               0.1
#  fallback     contingência de falha         deepseek/deepseek-chat     0.3
#
#  O juiz é de família DIFERENTE do gerador de propósito (viés de
#  autopreferência). Se trocar os modelos, preserve essa separação.
# ──────────────────────────────────────────────────────────────────────

# Trocar o modelo dos 3 alunos de uma vez:
#GEN_MODEL=google/gemini-3.5-flash

# Ou trocar um aluno específico:
#AGENT3A_MODEL=
#AGENT3B_MODEL=
#AGENT3C_MODEL=

# Trocar o juiz (mantenha família diferente do gerador):
#JUDGE_MODEL=z-ai/glm-4.5

# Trocar o fallback:
#FALLBACK_MODEL=deepseek/deepseek-chat

# Temperaturas (só mude se souber por quê; os padrões vêm da produção):
#AGENT3A_TEMP=0.2
#AGENT3B_TEMP=0.7
#AGENT3C_TEMP=0.4
#JUDGE_TEMP=0.1

# Logs detalhados:
#STI_LOG=debug
